# Copy to .env (gitignored) and fill in. Only the importer needs these; the
# `oncall` binary reads schedule.yaml and does not talk to Confluence.

CONFLUENCE_BASE=https://confluence.example.com
CONFLUENCE_SPACE=TEAM
CONFLUENCE_USER=you.name
ONCALL_PAGE_TITLE=Team On-Call Rotation Table

# Provide the password directly...
CONFLUENCE_PASSWORD=
# ...or point at a gopass secret to read it from instead:
# CONFLUENCE_PASS_GOPASS=team/confluence/you.name
